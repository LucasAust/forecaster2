# =============================================================================
# Arc Finance - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Public URL of your deployed app (used for OAuth redirects, metadata, etc.)
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://arcpredict.com

# Node environment (development, production, test)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
# -----------------------------------------------------------------------------

# Your Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (public, safe to expose to frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (private, server-side only, for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Plaid Configuration
# Get these from your Plaid dashboard: https://dashboard.plaid.com/
# -----------------------------------------------------------------------------

# Your Plaid client ID
PLAID_CLIENT_ID=your-plaid-client-id

# Your Plaid secret key (keep this secure!)
PLAID_SECRET=your-plaid-secret-key

# Plaid environment: sandbox, development, or production
PLAID_ENV=sandbox

# -----------------------------------------------------------------------------
# Google Gemini AI Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------

# Google Gemini API key for AI-powered financial insights
GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# Email Configuration (via Resend)
# Get your API key from: https://resend.com/api-keys
# -----------------------------------------------------------------------------

# Resend API key for sending emails (MFA codes, notifications)
RESEND_API_KEY=your-resend-api-key

# Email address to send from (must be verified in Resend)
EMAIL_FROM="Arc Finance <noreply@yourdomain.com>"

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# Secret key for signing MFA session cookies (generate a random 32+ char string)
MFA_COOKIE_SECRET=your-super-secret-mfa-cookie-signing-key-change-this

# -----------------------------------------------------------------------------
# Forecast Calibration Parameters (Optional - Advanced Tuning)
# These control the AI forecasting algorithm. Default values are used if not set.
# Only modify these if you understand the forecasting engine internals.
# -----------------------------------------------------------------------------

# Check density parameters
ARC_CAL_CHECK_DENSE_HIGH=0.7
ARC_CAL_CHECK_DENSE_LOW=0.3

# Cashout prediction parameters
ARC_CAL_CASHOUT_EXPECTED_MULT=1.0
ARC_CAL_CASHOUT_STALE_MULT=0.8
ARC_CAL_CASHOUT_CAP_MAX=5000
ARC_CAL_CASHOUT_CAP_SLOPE=0.1
ARC_CAL_CASHOUT_AMOUNT_CAP_MULT=1.2

# Source density parameters
ARC_CAL_SOURCE_DENSITY_BASE=0.1
ARC_CAL_SOURCE_DENSITY_SLOPE=0.05
ARC_CAL_SOURCE_DENSITY_MAX=0.9

# Miscellaneous calibration
ARC_CAL_MISC_CAP=1000
ARC_CAL_MISC_CHECK_WEIGHT=0.5
ARC_CAL_MISC_OTHER_WEIGHT=0.3
ARC_CAL_MISC_RECENT_BOOST=1.1

# Other transaction handling
ARC_CAL_OTHER_DENSE_MULT=0.9
ARC_CAL_OTHER_STALE_MULT=0.7

# Optimization parameters
ARC_OPT_EXPENSE_PENALTY=0.1
ARC_OPT_EXPENSE_TARGET=2000
ARC_OPT_INCOME_PENALTY=0.05
ARC_OPT_INCOME_TARGET=3000
ARC_OPT_SOURCE_MIN_ACTUAL=100
ARC_OPT_SOURCE_PENALTY=0.2
ARC_OPT_USE_CORE_METRIC=true
ARC_OPT_WORST_MONTH_PENALTY=0.15

# -----------------------------------------------------------------------------
# System Variables (Usually Auto-Set)
# These are typically set by your hosting platform or build system
# -----------------------------------------------------------------------------

# HOST=localhost
# PORT=3000
# PATH=/usr/local/bin:/usr/bin:/bin